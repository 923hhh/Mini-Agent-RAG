LLM_PROVIDER: openai_compatible
OLLAMA_BASE_URL: http://127.0.0.1:11434
OPENAI_COMPATIBLE_BASE_URL: https://api.deepseek.com/v1
OPENAI_COMPATIBLE_API_KEY: ''
OPENAI_COMPATIBLE_TIMEOUT_SECONDS: 120
OPENAI_COMPATIBLE_MAX_RETRIES: 2
DEFAULT_LLM_MODEL: deepseek-chat
QUERY_REWRITE_MODEL: deepseek-chat
DEFAULT_EMBEDDING_MODEL: bge-m3:latest
RERANK_MODEL: ./data/models/bge-reranker-base
RERANK_DEVICE: cpu
AGENT_MODEL: deepseek-chat
IMAGE_VLM_ENABLED: true
IMAGE_VLM_AUTO_CAPTION_ENABLED: false
IMAGE_VLM_PROVIDER: openai_compatible
IMAGE_VLM_API_STYLE: chat_completions
IMAGE_VLM_BASE_URL: https://ark.cn-beijing.volces.com/api/v3
IMAGE_VLM_API_KEY: ''
IMAGE_VLM_MODEL: doubao-seed-2-0-pro-260215
IMAGE_VLM_TIMEOUT_SECONDS: 120
IMAGE_VLM_MAX_TOKENS: 768
IMAGE_VLM_MAX_SIDE: 1600
IMAGE_VLM_PROMPT: ''
IMAGE_VLM_USE_OCR_CONTEXT: true
IMAGE_VLM_AUTO_TRIGGER_BY_OCR: false
IMAGE_VLM_SKIP_IF_OCR_CHARS_AT_LEAST: 20
IMAGE_VLM_ONLY_WHEN_OCR_EMPTY: true
IMAGE_VLM_REGION_CAPTION_ENABLED: true
IMAGE_VLM_REGION_MAX_REGIONS: 3
IMAGE_VLM_REGION_MIN_SIDE: 320
TEMPERATURE: 0.3
MAX_TOKENS: 2048
ENABLE_STREAMING: true

# 推荐通过环境变量注入敏感信息，而不是直接写入 model_settings.yaml：
#   OPENAI_COMPATIBLE_API_KEY=<your_llm_api_key>
#   OPENAI_COMPATIBLE_BASE_URL=<your_llm_base_url>
#   IMAGE_VLM_API_KEY=<your_image_vlm_api_key>
#   IMAGE_VLM_BASE_URL=<your_image_vlm_base_url>
